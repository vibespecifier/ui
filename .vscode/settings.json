{
  "files.encoding": "utf8",
  "files.eol": "\n",
  "editor.tabSize": 2,
  "editor.rulers": [80],

  // Auto format on save (requires recommended extension).
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": { "source.organizeImports": "always" },
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Code spell checker (require recommended extension).
  "cSpell.ignorePaths": [".git", "node_modules", "pnpm-lock.yaml"],
  "cSpell.words": ["esbenp", "oxlint"]
}
