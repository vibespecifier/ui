{
  "files.encoding": "utf8",
  "files.eol": "\n",
  "editor.tabSize": 2,
  "editor.rulers": [80],

  // CSS module support requires workspace version of TS SDK.
  "typescript.tsdk": "node_modules/typescript/lib",

  // Auto format on save (requires recommended extension).
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": { "source.organizeImports": "always" },
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // File nesting patterns (enable as you need).
  "explorer.fileNesting.patterns": {
    "*.tsx": "${capture}.module.css, ${capture}.test.ts",
    "*.js": ""
  },

  // Generated file bundles.
  "editor.wordWrapColumn": 80,
  "[javascript]": { "editor.wordWrap": "wordWrapColumn" },
  "[css]": { "editor.wordWrap": "wordWrapColumn" },

  // Code spell checker (require recommended extension).
  "cSpell.ignorePaths": [".git", "node_modules", "out", "pnpm-lock.yaml"],
  "cSpell.words": ["esbenp", "oxlint", "unplugin"]
}
